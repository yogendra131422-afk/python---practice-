# array reversal using two pointers 
a = [10,20,30,40,50,60,70,8,90,100,110,120,130,140,150,160,170,180,190,200,210,220,230,240,250,260,270,280,290,300]

left = 0

right = len(a)-1

while left<right:
    
    a[left], a[right] = a[right], a[left]

    left = left + 1
    right = right - 1

print(a)

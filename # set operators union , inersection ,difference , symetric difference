# set operators union , inersection ,difference , symetric difference 

a = {10,20,30}
b = { 40,50,10}

print(a|b)            # union = it means print unique values .

print(a&b)            # intersection = it means print common values

print(a - b)          # difference : only present a not present in b

print(b - a)          # difference : only present b not present in a

print(a ^ b)          # symetric :  remove common values and print remaning values 


